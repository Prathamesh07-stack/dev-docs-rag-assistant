# Environment variables — copy to .env and fill in values
# DO NOT commit .env to git

# App
ENV=development
DATA_DIR=./data
CONFIG_PATH=./config/sources.yaml

# LLM — FREE OPTIONS ONLY
# Option 1: Ollama (local, default — no key needed)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Other models: mistral, gemma3, deepseek-r1
# Pull with: ollama pull llama3.1:8b

# Option 2: Groq (free cloud API — much smarter, needs free key)
# Free tier: 14,400 req/day, Llama 3.3 70B quality
# Get free key: https://console.groq.com
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Chroma
CHROMA_PERSIST_DIR=./data/vectordb
CHROMA_COLLECTION=rag_docs

# CORS
ALLOWED_ORIGINS=http://localhost:3000
